{
  "name": "fishprint",
  "version": "2.30.0",
  "private": true,
  "scripts": {
    "start": "bun install --no-summary && bun daemon.ts",
    "daemon": "bun install --no-summary && bun daemon.ts",
    "daemon:install": "scripts/install-launchd.sh",
    "daemon:uninstall": "launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.moeki.fishprint.plist 2>/dev/null || true; rm -f ~/Library/LaunchAgents/com.moeki.fishprint.plist"
  },
  "dependencies": {
    "@moeki0/gengen": "^0.0.4",
    "playwright": "^1.52.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
